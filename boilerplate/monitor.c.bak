#include <linux/module.h>
#include <linux/kernel.h>
#include <linux/init.h>
#include <linux/fs.h>
#include <linux/uaccess.h>
#include <linux/slab.h>
#include <linux/cdev.h>
#include <linux/device.h>
#include <linux/pid.h>
#include <linux/sched/signal.h>
#include <linux/mm.h>
#include <linux/rcupdate.h>
#include <linux/signal.h>
#include <linux/timer.h>
#include <linux/jiffies.h>

#define DEVICE_NAME "container_monitor"
#define CLASS_NAME  "container"

#define MAX_CONTAINERS 32
#define MAX_ID_LEN 64

MODULE_LICENSE("GPL");

struct container_info {
    char id[MAX_ID_LEN];
    pid_t pid;
    long soft_limit;
    long hard_limit;
    int active;
};

static struct container_info containers[MAX_CONTAINERS];

static int major;
static struct class *monitor_class;
static struct device *monitor_device;

static struct timer_list monitor_timer;

/* ---------------- RSS ---------------- */

static long get_rss_bytes(pid_t pid)
{
    struct task_struct *task;
    struct mm_struct *mm;
    long rss_pages = 0;

    rcu_read_lock();
    task = pid_task(find_vpid(pid), PIDTYPE_PID);
    if (!task) {
        rcu_read_unlock();
        return -1;
    }
    get_task_struct(task);
    rcu_read_unlock();

    mm = get_task_mm(task);
    if (mm) {
        rss_pages = get_mm_rss(mm);
        mmput(mm);
    }

    put_task_struct(task);
    return rss_pages * PAGE_SIZE;
}

/* ---------------- LOG ---------------- */

static void log_soft_limit_event(const char *id,
                                 pid_t pid,
                                 long usage,
                                 long soft)
{
    printk(KERN_INFO "[container_monitor] WARNING: %s PID %d usage %ld > soft %ld\n",
           id, pid, usage, soft);
}

/* ---------------- KILL ---------------- */

static void kill_process(const char *id,
                         pid_t pid,
                         long usage,
                         long hard)
{
    struct task_struct *task;

    rcu_read_lock();
    task = pid_task(find_vpid(pid), PIDTYPE_PID);

    if (task) {
        printk(KERN_ALERT "[container_monitor] KILL: %s PID %d usage %ld > hard %ld\n",
               id, pid, usage, hard);

        send_sig(SIGKILL, task, 0);
    }

    rcu_read_unlock();
}

/* ---------------- MONITOR ---------------- */

static void monitor_fn(struct timer_list *t)
{
    int i;

    for (i = 0; i < MAX_CONTAINERS; i++) {

        if (!containers[i].active)
            continue;

        long usage = get_rss_bytes(containers[i].pid);

        if (usage < 0)
            continue;

        if (usage > containers[i].hard_limit) {
            kill_process(containers[i].id,
                         containers[i].pid,
                         usage,
                         containers[i].hard_limit);
        }
        else if (usage > containers[i].soft_limit) {
            log_soft_limit_event(containers[i].id,
                                 containers[i].pid,
                                 usage,
                                 containers[i].soft_limit);
        }
    }

    mod_timer(&monitor_timer, jiffies + msecs_to_jiffies(1000));
}

/* ---------------- IOCTL ---------------- */

#define CMD_ADD 1
#define CMD_REMOVE 2

struct container_request {
    char id[MAX_ID_LEN];
    pid_t pid;
    long soft_limit;
    long hard_limit;
};

static long device_ioctl(struct file *file,
                         unsigned int cmd,
                         unsigned long arg)
{
    struct container_request req;
    int i;

    if (copy_from_user(&req, (void __user *)arg, sizeof(req)))
        return -EFAULT;

    switch (cmd) {

    case CMD_ADD:
        for (i = 0; i < MAX_CONTAINERS; i++) {
            if (!containers[i].active) {
                containers[i].pid = req.pid;
                containers[i].soft_limit = req.soft_limit;
                containers[i].hard_limit = req.hard_limit;
                containers[i].active = 1;
                strncpy(containers[i].id, req.id, MAX_ID_LEN);
                break;
            }
        }
        break;

    case CMD_REMOVE:
        for (i = 0; i < MAX_CONTAINERS; i++) {
            if (containers[i].active &&
                strcmp(containers[i].id, req.id) == 0) {
                containers[i].active = 0;
                break;
            }
        }
        break;

    default:
        return -EINVAL;
    }

    return 0;
}

static struct file_operations fops = {
    .owner = THIS_MODULE,
    .unlocked_ioctl = device_ioctl,
};

/* ---------------- INIT ---------------- */

static int __init monitor_init(void)
{
    int i;

    for (i = 0; i < MAX_CONTAINERS; i++)
        containers[i].active = 0;

    major = register_chrdev(0, DEVICE_NAME, &fops);
    monitor_class = class_create(CLASS_NAME);
    monitor_device = device_create(monitor_class, NULL,
                                   MKDEV(major, 0),
                                   NULL, DEVICE_NAME);

    timer_setup(&monitor_timer, monitor_fn, 0);
    mod_timer(&monitor_timer, jiffies + msecs_to_jiffies(1000));

    printk(KERN_INFO "[container_monitor] Module loaded\n");
    return 0;
}

/* ---------------- EXIT ---------------- */

static void __exit monitor_exit(void)
{
   // del_timer(&monitor_timer);

    device_destroy(monitor_class, MKDEV(major, 0));
    class_destroy(monitor_class);
    unregister_chrdev(major, DEVICE_NAME);

    printk(KERN_INFO "[container_monitor] Module unloaded\n");
}

module_init(monitor_init);
module_exit(monitor_exit);
